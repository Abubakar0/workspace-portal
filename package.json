{
  "name": "workspace-portal",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run start:prod",
    "start:api": "tsx watch server/src/index.ts",
    "start:web": "ng serve --host 127.0.0.1 --port 4200",
    "start:prod": "prisma migrate deploy && npm run db:seed && node server/dist/index.js",
    "dev": "concurrently \"npm run start:api\" \"npm run start:web\"",
    "build": "ng build",
    "build:api": "tsc -p server/tsconfig.json",
    "build:all": "prisma generate && npm run build && npm run build:api",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.10",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "lucide-angular": "^1.0.0",
    "ngx-toastr": "^20.0.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
