generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  role         String
  team         String
  marketplace  String
  status       String
  shift        String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Team {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  marketplace String
  lead        String
  assigned    Int      @default(0)
  members     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Vps {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  team             String
  assignedEmployee String
  status           String
  connectionId     String   @unique
  marketplace      String
  region           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  actor     String
  action    String
  entity    String
  createdAt DateTime @default(now())
}
